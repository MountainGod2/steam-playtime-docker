{
  "extends": [
    "config:best-practices"
  ],
  "packageRules": [
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "8 days"
    }
  ],
  "pre-commit": {
    "enabled": true
  }
}
